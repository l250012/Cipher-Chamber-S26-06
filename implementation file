void HeartGame::handleClick(sf::Vector2f mousePos, Player& player, Game& gameInstance)
{
    if (gameOver || isWaiting) 
        return; 
    for (int i = 0; i < 3; i++)
    {
        if (playerBoxes[i].getGlobalBounds().contains(mousePos))
        {
            if (i == imposterIndex)
            {
                message.setString("Correct! You found the liar.");
                wonRound = true;
            }
            else
            {
                message.setString("Wrong! That person was innocent.");
                wonRound = false;
            }

            gameOver = true;
            isWaiting = true;       
            transitionClock.restart(); 
        }
    }
}
