TwoBlankPuzzle::TwoBlankPuzzle(const string& code, const string& a1, const string& a2, const string& a3, const string& h, int dmg)
    : Puzzle(code, "multi-blank", h, dmg), b1(a1), b2(a2), b3(a3), currentBlank(0) {
}

bool TwoBlankPuzzle::checkAnswer(const string& input) const
{
    string target = (currentBlank == 0) ? b1 : (currentBlank == 1) ? b2 : b3;
    return normalize(input) == normalize(target);
}

bool TwoBlankPuzzle::advanceBlank() 
{
    currentBlank++;
    return (currentBlank >= 3); 
}
string TwoBlankPuzzle::getBlankPrompt() const 
{
    if (currentBlank == 0) 
        return "Fill Blank 1...";
    if (currentBlank == 1)
        return "Fill Blank 2...";
    return "Fill Blank 3...";
}

