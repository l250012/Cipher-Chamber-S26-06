    healthBarBack.setFillColor(sf::Color(50, 50, 50)); 
    healthBarBack.setPosition(50.0f, 50.0f);

    // Bhara hua bar (Fill)
    healthBarFill.setFillColor(sf::Color::Red);
    healthBarFill.setPosition(50.0f, 50.0f);
    if (!font.loadFromFile("arial.ttf"))
    {
        std::cout << "Font loading failed!" << std::endl;
    }
    string dialogues[] = { "I'm innocent", "Trust me!", "He's the liar!" };
    float posX[] = { 400.0f, 650.0f, 900.0f }; //inki positions
    float posY = 260.0f;
    for (int i = 0; i < 3; i++)
    {
        playerBoxes[i].setSize(sf::Vector2f(140.0f, 45.0f));
        playerBoxes[i].setFillColor(sf::Color(0, 0, 0, 180)); 
        playerBoxes[i].setOutlineColor(sf::Color::White);
        playerBoxes[i].setOutlineThickness(2.0f);
        playerBoxes[i].setOrigin(70.0f, 22.5f);
        playerBoxes[i].setPosition(posX[i], posY);
        boxTexts[i].setFont(font);
        boxTexts[i].setString(dialogues[i]);
        boxTexts[i].setCharacterSize(18);
        boxTexts[i].setFillColor(sf::Color::White);
        sf::FloatRect textRect = boxTexts[i].getLocalBounds();
        boxTexts[i].setOrigin(textRect.left + textRect.width / 2.0f,
            textRect.top + textRect.height / 2.0f);
        boxTexts[i].setPosition(posX[i], posY);
    }
    message.setFont(font);
    message.setCharacterSize(40);
    message.setFillColor(sf::Color::White);
    message.setStyle(sf::Text::Bold);
    message.setString("");
    message.setPosition(400.0f, 100.0f);
}
void HeartGame::updatehover(sf::Vector2f mousePos)
{
    for (int i = 0; i < 3; i++)
    {
        if (playerBoxes[i].getGlobalBounds().contains(mousePos))
        {
            playerBoxes[i].setOutlineColor(sf::Color::Red);
        }
        else
        {
            playerBoxes[i].setOutlineColor(sf::Color::White);
        }
    }
}
void HeartGame::handleClick(sf::Vector2f mousePos, Player& player)
{
    if (gameOver || isWaiting) 
        return; 
    for (int i = 0; i < 3; i++)
    {
        if (playerBoxes[i].getGlobalBounds().contains(mousePos))
        {
            if (i == imposterIndex)
                message.setString("Correct! You found the liar.");
            else
            {
                message.setString("Wrong! That person was innocent.");
                HealthSystem::applyDamage(player, 20);
                cout << "Health Reduced! Current Health: " << player.getHealth() << endl;
            }

            gameOver = true;
            isWaiting = true;       
            transitionClock.restart(); 
        }
    }
}
void HeartGame::render(sf::RenderWindow& window, Player &player)
{
    window.draw(background); 
    float healthPercentage = static_cast<float>(player.getHealth()) / 100.0f;
    healthBarFill.setSize(sf::Vector2f(200.0f * healthPercentage, 20.0f));

    window.draw(healthBarBack);
    window.draw(healthBarFill);
    for (int i = 0; i < 3; i++)
    {
        window.draw(playerBoxes[i]); 
        window.draw(boxTexts[i]); 
    }
    if (gameOver) 
    {
        window.draw(message);
    }
}
bool HeartGame::shouldReturnToMenu() 
{
    if (isWaiting && transitionClock.getElapsedTime().asSeconds() >= 3.0f)
    {
        isWaiting = true; 
        gameOver = true;  
        return true;
    }
    return false;
}
Puzzle::Puzzle(const string& q, const string& ans, const string& h, int dmg)
    : questionText(q), correctAnswer(ans), hint(h), damageOnFail(dmg) {
}
// diamond game
string Puzzle::normalize(const string& s) 
{
    string res = s;
    res.erase(0, res.find_first_not_of(" "));
    res.erase(res.find_last_not_of(" ") + 1);
    for (char& c : res) c = tolower(c);
    return res;
}
bool Puzzle::checkAnswer(const string& input) const 
{
    return normalize(input) == normalize(correctAnswer);
}
// DiamondGame
DiamondGame::DiamondGame() : currentArenaIndex(0), challengeComplete(false)
{
    initArenas();
}
void DiamondGame::initArenas() 
{
    // Arena 1: Pointer Arithmetic
    arenas.push_back(Arena(1, "Entry Room", new OutputPredictPuzzle("int arr[]={10,20,30,40,50};\ncout<<*(ptr+2)<<\" \"<<*(ptr+4);", "30 50", "Check arr[2] and arr[4]", 10)));

    // Arena 2: Loop Logic
    arenas.push_back(Arena(2, "Mid Room", new DryRunPuzzle("for(int i=0;i<8;i++){\nif(i%2==0) continue;\nif(i==5) break;\ncout<<i<<\" \";}", "1 3", "Odd numbers before 5", 20)));

    arenas.push_back(Arena(3, "Boss Room", new OutputPredictPuzzle("int fact(int n){\nif(n<=___) return ___;\nreturn n*fact(___);}","1 1 n-1","Base case 1, return 1, recurse n-1", 30)));
}

DiamondGame::~DiamondGame()
{
    for (auto& a : arenas) delete a.puzzle;
}
void DiamondGame::startChallenge(Player& player) 
{
    currentArenaIndex = 0;
    challengeComplete = false;
    for (auto& a : arenas)
        a.isCleared = false;
}
bool DiamondGame::submitAnswer(Player& player, const string& input)
{
    if (currentArenaIndex >= arenas.size()) 
        return false;

    Puzzle* p = arenas[currentArenaIndex].puzzle;
    if (p->checkAnswer(input)) 
    {
        arenas[currentArenaIndex].isCleared = true;
        currentArenaIndex++;

        HealthSystem::regenerate(player);
        if (currentArenaIndex >= arenas.size())
        {
            challengeComplete = true;
            isWaitingToReturn = true;
            completionClock.restart();
        }
        return true;
    }
    else 
    {
        HealthSystem::applyDamage(player, p->getDamage());
        return false;
    }
}
Puzzle* DiamondGame::getCurrentPuzzle() const 
{
    if (currentArenaIndex < arenas.size()) 
        return arenas[currentArenaIndex].puzzle;
    return nullptr;
}
void DiamondGame::render(sf::RenderWindow& window, Player& player, const string& currentInput)
{
    // 1. Background draw karein
    window.draw(diamondBG);

    // 2. Health Bar (Wahi logic jo Heart Game mein thi)
    float healthPercentage = static_cast<float>(player.getHealth()) / 100.0f;
    sf::RectangleShape healthBarBack(sf::Vector2f(200.0f, 20.0f));
    healthBarBack.setFillColor(sf::Color(50, 50, 50));
    healthBarBack.setPosition(50.0f, 50.0f);


    sf::RectangleShape healthBarFill(sf::Vector2f(200.0f * healthPercentage, 20.0f));
    healthBarFill.setFillColor(sf::Color::Cyan); // Diamond game ke liye Cyan color
    healthBarFill.setPosition(50.0f, 50.0f);

    window.draw(healthBarBack);
    window.draw(healthBarFill);

    // 3. Current Arena aur Question display karein
    Puzzle* currentPuzzle = getCurrentPuzzle();
    if (currentPuzzle)
    {
        // Arena Title 
        arenaTitle.setString("ARENA " + to_string(currentArenaIndex + 1));
        window.draw(arenaTitle);
        // Question/Code Display
        window.draw(questionBox);
        questionDisplay.setString(currentPuzzle->getQuestion());
        window.draw(questionDisplay);
        // Input Text draw hoga yahan
        window.draw(inputBox);
        inputDisplay.setString("> " + currentInput + "_");
        window.draw(inputDisplay);
        inputDisplay.setString("> " + currentInput + "_");
        window.draw(inputDisplay);
    }
    else if (challengeComplete)
    {
        window.draw(completeBox);
        arenaTitle.setString("CHALLENGE COMPLETE!");
        arenaTitle.setPosition(400.0f, 340.0f);
        arenaTitle.setFillColor(sf::Color(0, 255, 0)); 
        window.draw(arenaTitle);
    }
}
