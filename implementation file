SpadeGame::SpadeGame() : wonRound(false), gameOver(false), fontLoaded(false) {
    if (font.loadFromFile("arial.ttf")) 
    { 
        fontLoaded = true;
    }
}

void SpadeGame::initLevel(int difficulty) 
{
    cols = 10 + difficulty; 
    rows = cols;
    cellSize = 500.0f / cols; 
    maze.clear();
    maze.resize(rows, std::vector<MazeCell>(cols));
    srand(static_cast<unsigned int>(time(0)));
    generateMaze(0, 0);
    playerPos = sf::Vector2i(0, 0);
    goalPos = sf::Vector2i(cols - 1, rows - 1);
    timeLimit = 25.0f;
    timeLeft = timeLimit;
    wonRound = false;
    gameOver = false;
    gameClock.restart();
    if (spadeBgTex.loadFromFile("spadesbackground.png")) 
    { 
        spadeBgSprite.setTexture(spadeBgTex);
        // Image ko 1280x720 ki screen par stretch karne ke liye:
        spadeBgSprite.setScale(
            1280.0f / spadeBgTex.getSize().x,
            720.0f / spadeBgTex.getSize().y
        );
        spadeBgSprite.setTexture(spadeBgTex);
    }
}

void SpadeGame::generateMaze(int x, int y) {
    maze[y][x].visited = true;
    int dirs[] = { 0, 1, 2, 3 }; // 0:Top, 1:Right, 2:Bottom, 3:Left

    // Shuffle directions
    for (int i = 0; i < 4; i++) {
        int r = rand() % 4;
        std::swap(dirs[i], dirs[r]);
    }

    for (int i = 0; i < 4; i++) {
        int nx = x, ny = y;
        if (dirs[i] == 0) ny--;
        else if (dirs[i] == 1) nx++;
        else if (dirs[i] == 2) ny++;
        else if (dirs[i] == 3) nx--;

        if (nx >= 0 && nx < cols && ny >= 0 && ny < rows && !maze[ny][nx].visited) {
            maze[y][x].walls[dirs[i]] = false;
            maze[ny][nx].walls[(dirs[i] + 2) % 4] = false;
            generateMaze(nx, ny);
        }
    }
}

void SpadeGame::handleInput(sf::Keyboard::Key key) {
    if (gameOver) return;

    if ((key == sf::Keyboard::W || key == sf::Keyboard::Up) && !maze[playerPos.y][playerPos.x].walls[0])
        playerPos.y--;
    else if ((key == sf::Keyboard::D || key == sf::Keyboard::Right) && !maze[playerPos.y][playerPos.x].walls[1])
        playerPos.x++;
    else if ((key == sf::Keyboard::S || key == sf::Keyboard::Down) && !maze[playerPos.y][playerPos.x].walls[2])
        playerPos.y++;
    else if ((key == sf::Keyboard::A || key == sf::Keyboard::Left) && !maze[playerPos.y][playerPos.x].walls[3])
        playerPos.x--;

    if (playerPos == goalPos) {
        wonRound = true;
        gameOver = true;
    }
}

void SpadeGame::update(float dt, Player& player) {
    if (!gameOver) {
        timeLeft -= dt;
        if (timeLeft <= 0) {
            timeLeft = 0;
            gameOver = true;
            wonRound = false;
        }
    }
}
void SpadeGame::draw(sf::RenderWindow& window) {
    // 1. Background draw (Ab ye poori screen cover karega)
    window.draw(spadeBgSprite);

    // 2. COORDINATES FIX (Background stretch hone ke baad ki values)
    // In values ko maine aapki original image ke grid ke hisaab se adjust kiya hai
    float offsetX = 305.0f;
    float offsetY = 180.0f;
    float totalMazeWidth = 670.0f;  // Grid ki poori width (right tak)
    float totalMazeHeight = 410.0f; // Grid ki poori height

    // Cell size calculate karein (rows aur cols ke mutabiq)
    float cellW = totalMazeWidth / cols;
    float cellH = totalMazeHeight / rows;

    // 3. Maze ki Walls
    for (int y = 0; y < rows; y++) {
        for (int x = 0; x < cols; x++) {
            float px = offsetX + x * cellW;
            float py = offsetY + y * cellH;

            sf::RectangleShape wall;
            wall.setFillColor(sf::Color(255, 0, 0, 220)); // Bright Red

            if (maze[y][x].walls[0]) { // Top
                wall.setSize({ cellW, 2 });
                wall.setPosition(px, py);
                window.draw(wall);
            }
            if (maze[y][x].walls[1]) { // Right
                wall.setSize({ 2, cellH });
                wall.setPosition(px + cellW, py);
                window.draw(wall);
            }
            if (maze[y][x].walls[2]) { // Bottom
                wall.setSize({ cellW, 2 });
                wall.setPosition(px, py + cellH);
                window.draw(wall);
            }
            if (maze[y][x].walls[3]) { // Left
                wall.setSize({ 2, cellH });
                wall.setPosition(px, py);
                window.draw(wall);
            }
        }
    }

    //  Goal (Yellow Square)
    sf::RectangleShape goal(sf::Vector2f(cellW * 0.7f, cellH * 0.7f));
    goal.setFillColor(sf::Color::Yellow);
    goal.setOrigin(goal.getSize().x / 2.0f, goal.getSize().y / 2.0f);
    goal.setPosition(offsetX + goalPos.x * cellW + cellW / 2.0f,
        offsetY + goalPos.y * cellH + cellH / 2.0f);
    window.draw(goal);

    //  Player (Cyan Circle)
    sf::CircleShape playerCircle(std::min(cellW, cellH) * 0.35f);
    playerCircle.setFillColor(sf::Color::Cyan);
    playerCircle.setOrigin(playerCircle.getRadius(), playerCircle.getRadius());
    playerCircle.setPosition(offsetX + playerPos.x * cellW + cellW / 2.0f,
        offsetY + playerPos.y * cellH + cellH / 2.0f);
    window.draw(playerCircle);

    //  UI: Timer aur Messages
    if (fontLoaded) {
        sf::Text timerText("Time: " + std::to_string((int)timeLeft), font, 35);
        timerText.setPosition(50, 40);
        timerText.setOutlineThickness(2);
        timerText.setOutlineColor(sf::Color::Black);
        window.draw(timerText);
    }

    if (gameOver) {
        sf::RectangleShape overlay(sf::Vector2f(1280, 720));
        overlay.setFillColor(sf::Color(0, 0, 0, 180));
        window.draw(overlay);

        sf::Text msg(wonRound ? "CHALLENGE COMPLETED" : "TIME OVER!", font, 75);
        msg.setFillColor(wonRound ? sf::Color::Green : sf::Color::Red);
        msg.setStyle(sf::Text::Bold);
        sf::FloatRect tr = msg.getLocalBounds();
        msg.setOrigin(tr.left + tr.width / 2.0f, tr.top + tr.height / 2.0f);
        msg.setPosition(640, 360);
        window.draw(msg);
    }
}
