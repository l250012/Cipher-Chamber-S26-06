void ClubGame::inputChoice(std::string choice) {
    if (gameOver)
        return;

    p1->choice = choice;

    std::string options[] = { "P", "H", "R" };
    int followChance = 55;
    if ((rand() % 100) < followChance)
        p2->choice = p1->choice;
    else
        p2->choice = options[rand() % 3];

    if ((rand() % 100) < followChance)
        p3->choice = p1->choice;
    else
        p3->choice = options[rand() % 3];

    evaluateRound();
}
void ClubGame::evaluateRound() {
    if (p1->choice == p2->choice && p2->choice == p3->choice) 
    {
        syncPercent += 10.0f; // Pehle 15 tha, ab 10 kiya (Jeetna thoda slow)
        lastImpact = "PERFECT SYNC! +10";
    }
    else if (p1->choice == p2->choice || p1->choice == p3->choice || p2->choice == p3->choice) {
        syncPercent += 2.0f; 
        lastImpact = "PARTIAL SYNC! +2";
    }
    else 
    {
        syncPercent -= 20.0f; // Badi penalty! Aik galti aur 20% bar saaf
        lastImpact = "TOTAL MISMATCH! -20";
    }

    showFeedback = true;
    feedbackClock.restart();
    syncPercent = std::max(0.0f, std::min(100.0f, syncPercent));
    if (syncPercent >= 100.0f || syncPercent <= 0.0f) 
    {
        gameOver = true;
        isWaitingToReturn = true;
        transitionClock.restart();
        result = (syncPercent >= 100.0f) ? "SUCCESS!" : "FAILED!";
    }
}
