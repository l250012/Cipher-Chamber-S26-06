void ClubGame::inputChoice(std::string choice) {
    if (gameOver)
        return;

    p1->choice = choice;
    // Simple NPC logic
    std::string options[] = { "P", "H", "R" };
    p2->choice = options[rand() % 3];
    p3->choice = options[rand() % 3];

    evaluateRound();
}

void ClubGame::render(sf::RenderWindow& window) 
{
    window.draw(bgSprite);
    syncBarFill.setSize({ (syncPercent / 100.0f) * 400.0f, 30.0f });
    window.draw(syncBarBack);
    window.draw(syncBarFill);
    window.draw(btnPress);
    window.draw(btnHold);
    window.draw(btnRelease);
    syncLabel.setString("SYNC: " + std::to_string((int)syncPercent) + "%");
    window.draw(syncLabel);
    if (gameOver) {
        syncLabel.setString(result); 
        syncLabel.setPosition(540, 300); 
        window.draw(syncLabel);
    }
}
void ClubGame::evaluateRound() 
{
    if (p1->choice == p2->choice && p2->choice == p3->choice)
        syncPercent += 15.0f;
    else
        syncPercent -= 10.0f;

    if (syncPercent >= 100.0f || syncPercent <= 0.0f)
    {
        syncPercent = std::max(0.0f, std::min(100.0f, syncPercent));
        gameOver = true;
        isWaitingToReturn = true;
        transitionClock.restart();
        result = (syncPercent >= 100.0f) ? "SUCCESS!" : "FAILED!";
    }
}
