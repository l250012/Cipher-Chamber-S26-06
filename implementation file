//MenuButton ki Logic 
bool MenuButton::isHovered(sf::Vector2i mousePos) 
{
    return box.getGlobalBounds().contains(static_cast<sf::Vector2f>(mousePos));
}
void MenuButton::updateVisuals(sf::Vector2i mousePos) 
{
    if (isHovered(mousePos)) 
    {
        box.setOutlineColor(sf::Color::Red);
        box.setOutlineThickness(3);
    }
    else 
    {
        box.setOutlineColor(sf::Color::White);
        box.setOutlineThickness(1);
    }
}
// player class
void Player::takeDamage(int dmg)
{
    health -= dmg;
    if (health < 0) health = 0;
}
void Player::heal(int amount)
{
    health += amount;
    if (health > 100) health = 100;
}
int Player::getHealth() const
{
    return health;
}
// health class
void HealthSystem::applyDamage(Player& player, int dmg)
{
    player.takeDamage(dmg);
}
void HealthSystem::regenerate(Player& player) 
{
    player.heal(1);
}
