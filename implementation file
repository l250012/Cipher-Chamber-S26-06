void Game::run()
{
    sf::Clock clock; 
    while (window.isOpen())
    {
        sf::Time elapsed = clock.restart();
        float dt = elapsed.asSeconds();
        processEvents();
        update(dt); 
        render();
    }
}
void Game::processEvents()
{
    sf::Event event;
    while (window.pollEvent(event))
    {
        // 1. Window Close Logic
        if (event.type == sf::Event::Closed)
            window.close();
        if (currentState == PLAYING_SPADE && event.type == sf::Event::KeyPressed)
        {
            spadeGame.handleInput(event.key.code);
        }
        // 2. Keyboard Input (Sirf Diamond Game ke liye)
        if (currentState == PLAYING_DIAMOND && event.type == sf::Event::TextEntered)
        {
            if (event.text.unicode == 8) // Backspace
            {
                if (!playerInputString.empty())
                    playerInputString.pop_back();
            }
            else if (event.text.unicode == 13) // Enter
            {
                diamondGame.submitAnswer(player, playerInputString);
                playerInputString.clear();
            }
            else if (event.text.unicode < 128) // Valid ASCII
            {
                playerInputString += static_cast<char>(event.text.unicode);
            }
        }

        // 3. Mouse Click Handling
        if (event.type == sf::Event::MouseButtonPressed && event.mouseButton.button == sf::Mouse::Left)
        {
            sf::Vector2i mousePos = sf::Mouse::getPosition(window);
            sf::Vector2f mousePosF = window.mapPixelToCoords(mousePos);

            switch (currentState)
            {
            case MENU:
                if (gfx.startBtn.isHovered(mousePos))
                    currentState = LEVEL_SELECT;
                else if (gfx.exitBtn.isHovered(mousePos))
                    window.close();
                break;

            case LEVEL_SELECT:
                // Door 1: Club Game 
                if (gfx.door1.getGlobalBounds().contains(mousePosF)) {
                    clubGame.initPlayers(player, npc1, npc2); // Players link karein
                    clubGame.loadAssets(gfx.font);           // Assets load karein
                    currentState = PLAYING_CLUB;
                }
                // Door 2: Heart Game
                else if (gfx.door2.getGlobalBounds().contains(mousePosF)) {
                    heartGame.loadAssets();
                    currentState = Heart_Playing;
                }
                // Door 3: Diamond Game
                else if (gfx.door3.getGlobalBounds().contains(mousePosF)) {
                    diamondGame.startChallenge(player);
                    diamondGame.loadVisuals(gfx.font);
                    playerInputString.clear();
                    currentState = PLAYING_DIAMOND;
                }
                else if (gfx.door4.getGlobalBounds().contains(mousePosF))
                {
                    spadeGame.initLevel(2); 
                    currentState = PLAYING_SPADE; 
                }
                break;

            case Heart_Playing: // Heart Game
                heartGame.handleClick(mousePosF, player, *this);
                break;

            case PLAYING_CLUB:
                // Club Game ke buttons check karein
                if (clubGame.btnPress.getGlobalBounds().contains(mousePosF))
                    clubGame.inputChoice("P");
                else if (clubGame.btnHold.getGlobalBounds().contains(mousePosF))
                    clubGame.inputChoice("H");
                else if (clubGame.btnRelease.getGlobalBounds().contains(mousePosF))
                    clubGame.inputChoice("R");
                break;
            case GAME_OVER:
            {
                sf::Vector2i mousePos = sf::Mouse::getPosition(window);
                if (restartButton.isHovered(mousePos)) // actual mein exit button ki hai
                {
                    window.close();
                }
                else if (menuButton.isHovered(mousePos))
                {
                    totalLives = 4;
                    player.heal(100);
                    currentState = MENU;
                }
            }
                break;
            case GAME_WIN:
            {
                if (event.type == sf::Event::MouseButtonPressed && event.mouseButton.button == sf::Mouse::Left) {
                    sf::Vector2i mousePos = sf::Mouse::getPosition(window);
                    if (invisibleMenuBtn.getGlobalBounds().contains(static_cast<sf::Vector2f>(mousePos))) {
                        winPoints = 0;    
                        totalLives = 4;     
                        currentState = MENU; 
                    }
                }
            }
                break;
            default:
                break;
            }
        }
    }
}
void Game::update(float dt)
{
    sf::Vector2i mousePos = sf::Mouse::getPosition(window);
    sf::Vector2f mousePosF = static_cast<sf::Vector2f>(mousePos);
    if (totalLives <= 0)
    {
        currentState = GAME_OVER;
        return;
    }
    if (currentState == PLAYING_SPADE)
    {
        spadeGame.update(dt, player);
        if (spadeGame.gameOver)
        {
            render();
            sf::sleep(sf::seconds(2.0f));
            if (spadeGame.wonRound)
            {
                winPoints++; 
                if (winPoints >= 4)
                    currentState = GAME_WIN;
                else 
                    currentState = LEVEL_SELECT;
            }
            else
            {
                totalLives--; 
                if (totalLives <= 0)
                    currentState = GAME_OVER;
                else
                    currentState = LEVEL_SELECT;
            }
            spadeGame.gameOver = false;
        }
    }
    if (currentState == Heart_Playing)
    {
        heartGame.updatehover(mousePosF);
        if (heartGame.isWaiting && heartGame.transitionClock.getElapsedTime().asSeconds() >= 3.0f)
        {
            if (!heartGame.wonRound) 
            {
                handleMiniGameLoss(); 
            }
            else
            {
                winPoints++;
                if (winPoints >= 4) 
                    currentState = GAME_WIN;
                else
                {
                    currentState = LEVEL_SELECT;
                }
            }
            heartGame.isWaiting = false;
            heartGame.gameOver = false;
            heartGame.wonRound = false;
        }
    }
    else if (currentState == MENU)
    {
        gfx.startBtn.updateVisuals(mousePos);
        gfx.exitBtn.updateVisuals(mousePos);
    }
    else if (currentState == LEVEL_SELECT)
    {
        sf::Sprite* doors[] = { &gfx.door1, &gfx.door2, &gfx.door3, &gfx.door4 };
        for (auto d : doors)
        {
            if (d->getGlobalBounds().contains(mousePosF))
            {
                d->setColor(sf::Color::White);
                d->setScale(0.55f, 0.55f);
            }
            else
            {
                d->setColor(sf::Color(150, 150, 150)); 
                d->setScale(0.5f, 0.5f);
            }
        }
    }
    if (currentState == PLAYING_DIAMOND)
    {
        if (diamondGame.isWaitingToReturn && diamondGame.completionClock.getElapsedTime().asSeconds() >= 3.0f)
        {
            if (player.getHealth() <= 0) 
            {
                handleMiniGameLoss();  
                currentState = LEVEL_SELECT;     
            }
            else if (diamondGame.challengeComplete)
            {
                winPoints++; 
                if (winPoints >= 4)
                    currentState = GAME_WIN;
                else 
                    currentState = LEVEL_SELECT;
            }
            diamondGame.isWaitingToReturn = false;
            diamondGame.challengeComplete = false;
            player.heal(100);
            diamondGame.startChallenge(player);
        }
    }
    if (currentState == PLAYING_CLUB)
    {
        if (clubGame.gameOver && clubGame.transitionClock.getElapsedTime().asSeconds() >= 3.0f)
        {
            if (clubGame.result == "SUCCESS!")
            {
                winPoints++;
                if (winPoints >= 4)
                    currentState = GAME_WIN;
                else 
                    currentState = LEVEL_SELECT;
            }
            else 
            {
                handleMiniGameLoss();
            }
            clubGame.gameOver = false;
            clubGame.result = "";
        }
    }
    if (currentState == GAME_OVER)
    {
        restartButton.updateVisuals(mousePos);// exit button ki
        menuButton.updateVisuals(mousePos);
    }
    if (totalLives <= 0) {
        currentState = GAME_OVER; 
    }
}
void Game::render()
{
    window.clear();
    if (currentState == MENU) 
    {
        window.draw(gfx.bgMenuSprite);
        window.draw(gfx.title);
        window.draw(gfx.startBtn.box);
        window.draw(gfx.startBtn.label);
        window.draw(gfx.exitBtn.box);
        window.draw(gfx.exitBtn.label);
    }
    else if (currentState == LEVEL_SELECT)
    {
        window.draw(gfx.bgLevelSprite);
        window.draw(gfx.door1);
        window.draw(gfx.door2);
        window.draw(gfx.door3);
        window.draw(gfx.door4);
        gfx.drawLives(window, totalLives);
    }
    else if (currentState == Heart_Playing) {
        heartGame.render(window, player); 
    }
    else if (currentState == PLAYING_DIAMOND) 
    {
        diamondGame.render(window, player, playerInputString);
    }
    else if (currentState == PLAYING_CLUB) 
    {
        clubGame.render(window);
    }
    else if (currentState == PLAYING_SPADE)
    {
        spadeGame.draw(window);
    }
    else if (currentState == GAME_OVER)
    {
        window.draw(gameOverSprite);
        window.draw(restartButton.box);
        window.draw(restartButton.label);

        window.draw(menuButton.box);
        window.draw(menuButton.label);
    }
    else if (currentState == GAME_WIN)
    {
        window.draw(winScreenSprite);
        window.draw(invisibleMenuBtn); 
    }
    window.display();
}
void Game::handleMiniGameLoss() {
    HealthSystem::applyFatalDamage(totalLives);
    if (totalLives <= 0) {
        cout << "GAME OVER! No lives left." << endl;
        currentState = GAME_OVER;
    }
    else {
        // Wapas level select ya main screen par bhej dein
        currentState = LEVEL_SELECT;
    }
}
