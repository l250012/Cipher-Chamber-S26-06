#include "DiamondGame.h"

Puzzle::Puzzle(const string& q, const string& a, const string& h, int d)
    : questionText(q), correctAnswer(a), hint(h), damageOnFail(d) {}

Puzzle::~Puzzle() {}

string Puzzle::normalize(string s) {
    while (!s.empty() && s.front() == ' ') s.erase(s.begin());
    while (!s.empty() && s.back() == ' ') s.pop_back();

    for (char& c : s)
        if (c >= 'A' && c <= 'Z') c += 32;

    return s;
}

bool Puzzle::checkAnswer(const string& s) const {
    return normalize(s) == normalize(correctAnswer);
}

string Puzzle::getQuestion() const { return questionText; }
string Puzzle::getHint() const { return hint; }
string Puzzle::getAnswer() const { return correctAnswer; }
int Puzzle::getDamage() const { return damageOnFail; }

OutputPredictPuzzle::OutputPredictPuzzle(const string& a,const string& b,const string& c,int d)
    : Puzzle(a,b,c,d) {}

string OutputPredictPuzzle::getPuzzleType() const { return "OUTPUT_PREDICT"; }
string OutputPredictPuzzle::getInstructions() const { return "Predict output"; }

DryRunPuzzle::DryRunPuzzle(const string& a,const string& b,const string& c,int d,const string& v)
    : Puzzle(a,b,c,d), tracedVariable(v) {}

string DryRunPuzzle::getPuzzleType() const { return "DRY_RUN"; }
string DryRunPuzzle::getTracedVariable() const { return tracedVariable; }
string DryRunPuzzle::getInstructions() const { return "Trace code"; }

TwoBlankPuzzle::TwoBlankPuzzle(const string& a,const string& b,const string& c,const string& d,const string& e,int f)
    : Puzzle(a,b,c,f), blank1A(b), blank1B(c), blank2(d), currentBlank(0) {}

string TwoBlankPuzzle::getPuzzleType() const { return "TWO_BLANK"; }
string TwoBlankPuzzle::getInstructions() const { return "Fill blanks"; }

bool TwoBlankPuzzle::checkAnswer(const string& s) const {
    string in = Puzzle::normalize(s);
    if (currentBlank == 0) return in == normalize(blank1A);
    if (currentBlank == 1) return in == normalize(blank1B);
    if (currentBlank == 2) return in == normalize(blank2);
    return false;
}

bool TwoBlankPuzzle::advanceBlank() {
    if (currentBlank < 2) { currentBlank++; return false; }
    return true;
}

void TwoBlankPuzzle::resetBlanks() { currentBlank = 0; }

int TwoBlankPuzzle::getCurrentBlank() const { return currentBlank; }

string TwoBlankPuzzle::getBlankPrompt() const {
    if (currentBlank == 0) return "Blank 1A";
    if (currentBlank == 1) return "Blank 1B";
    if (currentBlank == 2) return "Blank 2";
    return "Done";
}

Arena::Arena() : arenaNumber(0), puzzle(nullptr), isCleared(false), hpSnapshot(100) {}

Arena::Arena(int a,const string& b,Puzzle* c)
    : arenaNumber(a), arenaName(b), puzzle(c), isCleared(false), hpSnapshot(100) {}

void DiamondGame::initArenas() {
    arenas[0] = Arena(1,"Entry",new OutputPredictPuzzle("a","30 50","h",10));
    arenas[1] = Arena(2,"Mid",new DryRunPuzzle("a","1 3","h",20,"i"));
    arenas[2] = Arena(3,"Boss",new TwoBlankPuzzle("a","1","1","n-1","h",30));
}

DiamondGame::DiamondGame()
    : currentArenaIndex(0), challengeComplete(false),
      arenaRestarted(false), wrongAttemptsThisArena(0) {
    initArenas();
}

DiamondGame::~DiamondGame() {
    for (int i = 0; i < 3; i++)
        delete arenas[i].puzzle;
}

void DiamondGame::startChallenge(Player& p) {
    currentArenaIndex = 0;
    challengeComplete = false;
}

bool DiamondGame::submitAnswer(Player& p, const string& s) {
    Arena& a = arenas[currentArenaIndex];

    if (a.puzzle->checkAnswer(s)) {
        a.isCleared = true;
        currentArenaIndex++;
        if (currentArenaIndex >= 3) challengeComplete = true;
        return true;
    }

    HealthSystem::applyDamage(p, a.puzzle->getDamage());
    return false;
}

Puzzle* DiamondGame::getCurrentPuzzle() const {
    if (currentArenaIndex >= 3) return nullptr;
    return arenas[currentArenaIndex].puzzle;
}

const Arena* DiamondGame::getCurrentArena() const {
    if (currentArenaIndex >= 3) return nullptr;
    return &arenas[currentArenaIndex];
}

bool DiamondGame::isChallengeComplete() const {
    return challengeComplete;
}
