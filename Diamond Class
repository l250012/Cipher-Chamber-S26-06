// 
//  Puzzle — abstract base
// 
class Puzzle {
protected:
    string questionText;
    string correctAnswer;
    string hint;
    int    damageOnFail;

public:
    Puzzle(const string& q, const string& ans,
           const string& h, int dmg)
        : questionText(q), correctAnswer(ans),
          hint(h), damageOnFail(dmg) {}

    virtual ~Puzzle() {}

    static string normalize(string s) {
        // trim left
        while (!s.empty() && s.front() == ' ')
            s.erase(s.begin());
        // trim right
        while (!s.empty() && s.back() == ' ')
            s.pop_back();

        // lowercase without <cctype>
        for (char& c : s) {
            if (c >= 'A' && c <= 'Z')
                c = c + 32;
        }
        return s;
    }

    virtual bool checkAnswer(const string& playerInput) const {
        return normalize(playerInput) == normalize(correctAnswer);
    }

    virtual string getPuzzleType() const = 0;

    string getQuestion() const { return questionText; }
    string getHint()     const { return hint; }
    string getAnswer()   const { return correctAnswer; }
    int    getDamage()   const { return damageOnFail; }
};


// 
//  Arena 1 — OutputPredictPuzzle
// 
class OutputPredictPuzzle : public Puzzle {
public:
    OutputPredictPuzzle(const string& code, const string& ans,
                        const string& h, int dmg)
        : Puzzle(code, ans, h, dmg) {}

    string getPuzzleType() const override {
        return "OUTPUT_PREDICT";
    }

    string getInstructions() const {
        return "What does the code print?";
    }
};



//  Arena 2 — DryRunPuzzle

class DryRunPuzzle : public Puzzle {
public:
    DryRunPuzzle(const string& code, const string& ans,
                 const string& h, int dmg, const string&)
        : Puzzle(code, ans, h, dmg) {}

    string getPuzzleType() const override {
        return "DRY_RUN";
    }

    string getInstructions() const {
        return "Trace the code output carefully.";
    }
};



//  Arena 3 — TwoBlankPuzzle

class TwoBlankPuzzle : public Puzzle {
private:
    string blank1A, blank1B, blank2;
    int currentBlank;

public:
    TwoBlankPuzzle(const string& code,
                   const string& b1a, const string& b1b,
                   const string& b2,
                   const string& h, int dmg)
        : Puzzle(code, "see blanks", h, dmg),
          blank1A(b1a), blank1B(b1b), blank2(b2),
          currentBlank(0) {}

    string getPuzzleType() const override {
        return "TWO_BLANK";
    }

    bool checkAnswer(const string& input) const override {
        string in = normalize(input);
        if (currentBlank == 0) return in == normalize(blank1A);
        if (currentBlank == 1) return in == normalize(blank1B);
        if (currentBlank == 2) return in == normalize(blank2);
        return false;
    }

    bool advanceBlank() {
        if (currentBlank < 2) {
            currentBlank++;
            return false;
        }
        return true;
    }

    void resetBlanks() { currentBlank = 0; }

    string getBlankPrompt() const {
        if (currentBlank == 0) return "Blank 1A: ___";
        if (currentBlank == 1) return "Blank 1B: ___";
        if (currentBlank == 2) return "Blank 2: ___";
        return "Done";
    }
};



//  Arena struct

struct Arena {
    int arenaNumber;
    string arenaName;
    Puzzle* puzzle;
    bool isCleared;
    int hpSnapshot;

    Arena() : arenaNumber(0), puzzle(nullptr),
              isCleared(false), hpSnapshot(100) {}

    Arena(int n, const string& name, Puzzle* p)
        : arenaNumber(n), arenaName(name),
          puzzle(p), isCleared(false), hpSnapshot(100) {}
};



//  DiamondGame

class DiamondGame : public Card {
private:
    Arena arenas[3];   
    int currentArenaIndex;
    bool challengeComplete;
    bool arenaRestarted;
    int wrongAttemptsThisArena;

    void initArenas();
    void restartCurrentArena(Player& player);

public:
    DiamondGame()
        : currentArenaIndex(0),
          challengeComplete(false),
          arenaRestarted(false),
          wrongAttemptsThisArena(0) {
        initArenas();
    }

    ~DiamondGame() {
        for (int i = 0; i < 3; i++)
            delete arenas[i].puzzle;
    }

    void initArenas() {
        arenas[0] = Arena(1, "Entry Room",
            new OutputPredictPuzzle(
                "int arr[]={10,20,30,40,50};",
                "30 50",
                "Pointer arithmetic",
                10
            )
        );

        arenas[1] = Arena(2, "Mid Room",
            new DryRunPuzzle(
                "for loop with break/continue",
                "1 3",
                "Trace carefully",
                20,
                "x"
            )
        );

        arenas[2] = Arena(3, "Boss Room",
            new TwoBlankPuzzle(
                "factorial function",
                "1", "1", "n-1",
                "Recursive thinking",
                30
            )
        );
    }

    void startChallenge(Player& player) override {
        currentArenaIndex = 0;
        challengeComplete = false;

        for (int i = 0; i < 3; i++)
            arenas[i].isCleared = false;
    }

    bool submitAnswer(Player& player, const string& input) {
        Arena& arena = arenas[currentArenaIndex];
        Puzzle* p = arena.puzzle;

        if (p->checkAnswer(input)) {
            arena.isCleared = true;
            currentArenaIndex++;

            if (currentArenaIndex >= 3)
                challengeComplete = true;

            return true;
        } else {
            HealthSystem::applyDamage(player, p->getDamage());
            return false;
        }
    }

    Puzzle* getCurrentPuzzle() const {
        if (currentArenaIndex >= 3) return nullptr;
        return arenas[currentArenaIndex].puzzle;
    }

    bool isChallengeComplete() const {
        return challengeComplete;
    }
};
