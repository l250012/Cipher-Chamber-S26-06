// ────────────────────────────────────────────────────────────────
// Puzzle
// ────────────────────────────────────────────────────────────────

Puzzle::Puzzle(const string& q, const string& ans,
               const string& h, int dmg)
    : questionText(q), correctAnswer(ans), hint(h), damageOnFail(dmg) {}

string Puzzle::normalize(const string& s) {
    string result = s;
    while (!result.empty() && result.front() == ' ')
        result.erase(result.begin());
    while (!result.empty() && result.back() == ' ')
        result.pop_back();

    for (char& c : result)
        c = tolower(c);

    return result;
}

bool Puzzle::checkAnswer(const string& playerInput) const {
    return normalize(playerInput) == normalize(correctAnswer);
}

string Puzzle::getQuestion() const { return questionText; }
string Puzzle::getHint() const { return hint; }
string Puzzle::getAnswer() const { return correctAnswer; }
int Puzzle::getDamage() const { return damageOnFail; }


