// ────────────────────────────────────────────────────────────────
// TwoBlankPuzzle
// ────────────────────────────────────────────────────────────────

TwoBlankPuzzle::TwoBlankPuzzle(const string& code,
                               const string& b1a, const string& b1b,
                               const string& b2,
                               const string& h, int dmg)
    : Puzzle(code, "see blanks", h, dmg),
      blank1A(b1a), blank1B(b1b), blank2(b2), currentBlank(0) {}

string TwoBlankPuzzle::getPuzzleType() const {
    return "TWO_BLANK";
}

string TwoBlankPuzzle::getInstructions() const {
    return "Fill in each blank one at a time. Press Enter after each answer.";
}

bool TwoBlankPuzzle::checkAnswer(const string& playerInput) const {
    string input = normalize(playerInput);

    if (currentBlank == 0) return input == normalize(blank1A);
    if (currentBlank == 1) return input == normalize(blank1B);
    if (currentBlank == 2) return input == normalize(blank2);

    return false;
}

bool TwoBlankPuzzle::advanceBlank() {
    if (currentBlank < 2) {
        currentBlank++;
        return false;
    }
    return true;
}

void TwoBlankPuzzle::resetBlanks() {
    currentBlank = 0;
}

int TwoBlankPuzzle::getCurrentBlank() const {
    return currentBlank;
}

string TwoBlankPuzzle::getBlankPrompt() const {
    if (currentBlank == 0)
        return "Blank 1A > if(n <= ___)";
    if (currentBlank == 1)
        return "Blank 1B > return ___";
    if (currentBlank == 2)
        return "Blank 2 > factorial(___)";
    return "Done";
}


