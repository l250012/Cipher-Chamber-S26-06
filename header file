//Diamond Game Classes
class Puzzle 
{
protected:
    string questionText, correctAnswer, hint;
    int damageOnFail;
public:
    Puzzle(const string& q, const string& ans, const string& h, int dmg);
    virtual ~Puzzle() {}
    virtual bool checkAnswer(const string& playerInput) const;
    virtual string getPuzzleType() const = 0;
    string getQuestion() const;
    string getHint() const;
    int getDamage() const;
    static string normalize(const string& s);
};
class OutputPredictPuzzle : public Puzzle
{
public:
    OutputPredictPuzzle(const string& code, const string& ans, const string& h, int dmg);
    string getPuzzleType() const override { return "OUTPUT_PREDICT"; }
};

class DryRunPuzzle : public Puzzle
{
public:
    DryRunPuzzle(const string& code, const string& ans, const string& h, int dmg);
    string getPuzzleType() const override { return "DRY_RUN"; }
};
class TwoBlankPuzzle : public Puzzle
{
private:
    string b1, b2, b3;
    int currentBlank;
public:
    TwoBlankPuzzle(const string& code, const string& a1, const string& a2, const string& a3, const string& h, int dmg);
    string getPuzzleType() const override { return "TWO_BLANK"; }
    bool checkAnswer(const string& input) const override;
    bool advanceBlank();
    void resetBlanks() { currentBlank = 0; }
    string getBlankPrompt() const;
};
struct Arena
{
    int arenaNumber;
    string arenaName;
    Puzzle* puzzle;
    bool isCleared;
    Arena(int num, const string& name, Puzzle* p) : arenaNumber(num), arenaName(name), puzzle(p), isCleared(false) {}
};
class DiamondGame 
{
private:
    vector<Arena> arenas;
    int currentArenaIndex;
    bool challengeComplete;
    void initArenas();
    sf::Text questionDisplay;
    sf::Text inputDisplay;
    sf::Text arenaTitle;
    sf::Sprite diamondBG;
    sf::Texture diamondTex;
    sf::RectangleShape inputBox; // Text ke peechay wala box
    sf::RectangleShape questionBox; // Code display ke liye box
    sf::RectangleShape completeBox; // Final message ke liye box

public:
    DiamondGame();
    ~DiamondGame();
    void startChallenge(Player& player);
    bool submitAnswer(Player& player, const string& input);
    Puzzle* getCurrentPuzzle() const;
    bool isComplete() const 
    {
        return challengeComplete;
    }
    void loadVisuals(sf::Font& font);
    void render(sf::RenderWindow& window, Player& player, const string& currentInput);
    sf::Clock completionClock; // Time track karne ke liye
    bool isWaitingToReturn = false;
};
