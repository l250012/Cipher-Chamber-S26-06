#pragma once
#include "Card.h"
#include "playerclass.h"
#include "HealthSystem.h"
#include <string>

using namespace std;

class Puzzle {
protected:
    string questionText, correctAnswer, hint;
    int damageOnFail;

public:
    Puzzle(const string&, const string&, const string&, int);
    virtual ~Puzzle();

    virtual bool checkAnswer(const string&) const;
    virtual string getPuzzleType() const = 0;

    string getQuestion() const;
    string getHint() const;
    string getAnswer() const;
    int getDamage() const;

protected:
    static string normalize(string);
};

class OutputPredictPuzzle : public Puzzle {
public:
    OutputPredictPuzzle(const string&, const string&, const string&, int);
    string getPuzzleType() const override;
    string getInstructions() const;
};

class DryRunPuzzle : public Puzzle {
    string tracedVariable;
public:
    DryRunPuzzle(const string&, const string&, const string&, int, const string&);
    string getPuzzleType() const override;
    string getTracedVariable() const;
    string getInstructions() const;
};

class TwoBlankPuzzle : public Puzzle {
    string blank1A, blank1B, blank2;
    int currentBlank;

public:
    TwoBlankPuzzle(const string&, const string&, const string&, const string&, const string&, int);
    string getPuzzleType() const override;
    string getInstructions() const;

    bool checkAnswer(const string&) const override;
    bool advanceBlank();
    void resetBlanks();
    int getCurrentBlank() const;
    string getBlankPrompt() const;
};

struct Arena {
    int arenaNumber;
    string arenaName;
    Puzzle* puzzle;
    bool isCleared;
    int hpSnapshot;

    Arena();
    Arena(int, const string&, Puzzle*);
};

class DiamondGame : public Card {
    Arena arenas[3];
    int currentArenaIndex;
    bool challengeComplete;
    bool arenaRestarted;
    int wrongAttemptsThisArena;

    void initArenas();
    void restartCurrentArena(Player&);

public:
    DiamondGame();
    ~DiamondGame();

    void startChallenge(Player&) override;
    bool submitAnswer(Player&, const string&);

    Puzzle* getCurrentPuzzle() const;
    const Arena* getCurrentArena() const;

    bool wasArenaRestarted();
    int getWrongAttempts() const;
    int getCurrentArenaIndex() const;
    int getTotalArenas() const;
    bool isChallengeComplete() const;
    bool isArenaUnlocked(int) const;
    bool isArenaCleared(int) const;
    string getCurrentBlankPrompt() const;
    string getSuit() const;
};
