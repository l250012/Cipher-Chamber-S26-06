#pragma once
#include "Card.h"
#include "playerclass.h"
#include "HealthSystem.h"
#include <string>
#include <vector>
using namespace std;

// ================================================================
// DiamondGame.h — declarations only
//
// Hierarchy:
// Puzzle (abstract)
// └── OutputPredictPuzzle (Arena 1)
// └── DryRunPuzzle (Arena 2)
// └── TwoBlankPuzzle (Arena 3)
// Arena (struct)
// DiamondGame : public Card
//
// No SFML — pure logic only.
// SFML friend reads getters every frame to drive rendering.
// ================================================================


// ────────────────────────────────────────────────────────────────
// Puzzle — abstract base
// ────────────────────────────────────────────────────────────────
class Puzzle {
protected:
    string questionText;
    string correctAnswer;
    string hint;
    int damageOnFail;

public:
    Puzzle(const string& q, const string& ans,
           const string& h, int dmg);

    virtual ~Puzzle() {}

    virtual bool checkAnswer(const string& playerInput) const;
    virtual string getPuzzleType() const = 0;

    string getQuestion() const;
    string getHint() const;
    string getAnswer() const;
    int getDamage() const;

protected:
    static string normalize(const string& s);
};


// ────────────────────────────────────────────────────────────────
// Arena 1 — OutputPredictPuzzle
// Pointer arithmetic — answer: "30 50" — damage: -10 HP
// ────────────────────────────────────────────────────────────────
class OutputPredictPuzzle : public Puzzle {
public:
    OutputPredictPuzzle(const string& code, const string& ans,
                        const string& h, int dmg);

    string getPuzzleType() const override;
    string getInstructions() const;
};


// ────────────────────────────────────────────────────────────────
// Arena 2 — DryRunPuzzle
// break/continue loop — answer: "1 3" — damage: -20 HP
// ────────────────────────────────────────────────────────────────
class DryRunPuzzle : public Puzzle {
private:
    string tracedVariable;

public:
    DryRunPuzzle(const string& code, const string& ans,
                 const string& h, int dmg, const string& varName);

    string getPuzzleType() const override;
    string getTracedVariable() const;
    string getInstructions() const;
};


// ────────────────────────────────────────────────────────────────
// Arena 3 — TwoBlankPuzzle
// Recursive factorial — 3 sequential blanks
// Blank 1A: "1" | Blank 1B: "1" | Blank 2: "n-1"
// damage: -30 HP per wrong blank
// ────────────────────────────────────────────────────────────────
class TwoBlankPuzzle : public Puzzle {
private:
    string blank1A;
    string blank1B;
    string blank2;
    int currentBlank; // 0 = blank1A, 1 = blank1B, 2 = blank2

public:
    TwoBlankPuzzle(const string& code,
                   const string& b1a, const string& b1b,
                   const string& b2,
                   const string& h, int dmg);

    string getPuzzleType() const override;
    string getInstructions() const;
    bool checkAnswer(const string& playerInput) const override;
    bool advanceBlank(); // returns true when all blanks done
    void resetBlanks();
    int getCurrentBlank() const;
    bool allBlanksComplete() const;
    string getBlankPrompt() const;
};


// ────────────────────────────────────────────────────────────────
// Arena struct
// ────────────────────────────────────────────────────────────────
struct Arena {
    int arenaNumber;
    string arenaName;
    Puzzle* puzzle;
    bool isCleared;
    int hpSnapshot;

    Arena(int num, const string& name, Puzzle* p);
};


// ────────────────────────────────────────────────────────────────
// DiamondGame — extends Card
// ────────────────────────────────────────────────────────────────
class DiamondGame : public Card {
private:
    vector<Arena> arenas;
    int currentArenaIndex;
    bool challengeComplete;
    bool arenaRestarted;
    int wrongAttemptsThisArena;

    void initArenas();
    void restartCurrentArena(Player& player);

public:
    DiamondGame();
    ~DiamondGame();

    void startChallenge(Player& player) override;
    bool submitAnswer(Player& player, const string& input);

    Puzzle* getCurrentPuzzle() const;
    const Arena* getCurrentArena() const;
    bool wasArenaRestarted();
    int getWrongAttempts() const;
    int getCurrentArenaIndex() const;
    int getTotalArenas() const;
    bool isChallengeComplete() const;
    bool isArenaUnlocked(int i) const;
    bool isArenaCleared(int i) const;
    string getCurrentBlankPrompt() const;
    string getSuit() const;
};
